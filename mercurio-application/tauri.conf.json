{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mercurio SysML Workbench",
  "version": "0.1.0",
  "identifier": "com.markpetrotta.mercurio",
  "build": {
    "frontendDist": "../mercurio-application-ui/dist",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm --prefix mercurio-application-ui run build && cargo build -p mercurio-cli --release --manifest-path Cargo.toml && powershell -NoProfile -Command \"$root = Resolve-Path ..; Copy-Item (Join-Path $root 'target\\\\release\\\\mercurio-cli.exe') (Join-Path $root 'target\\\\release\\\\mercurio-cli-x86_64-pc-windows-msvc.exe') -Force\""
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Mercurio SysML Workbench",
        "width": 1200,
        "height": 800,
        "minWidth": 960,
        "minHeight": 640,
        "decorations": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "..\\target\\release\\mercurio-cli"
    ],
    "windows": {
      "wix": {
        "fragmentPaths": [
          "wix\\path-env.wxs"
        ],
        "componentGroupRefs": [
          "PathEnvGroup"
        ]
      }
    },
    "resources": [
      "stdlib-packaged/manifest.json",
      "stdlib-packaged/system-release-122025.zip",
      "llm/instructions.md",
      "llm/hints.json"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
