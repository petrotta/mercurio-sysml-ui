{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mercurio SysML Workbench",
  "version": "0.1.0",
  "identifier": "com.markpetrotta.mercurio",
  "build": {
    "frontendDist": "../mercurio-frontend"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Mercurio SysML Workbench",
        "width": 1200,
        "height": 800,
        "minWidth": 960,
        "minHeight": 640,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
