{
  "name": "mercurio-frontend-react",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test:path-utils": "tsc --pretty false --module esnext --target ES2022 --moduleResolution bundler --outDir .tmp-path-tests src/app/pathUtils.ts src/app/pathUtils.spec.ts && node .tmp-path-tests/pathUtils.spec.js && node -e \"require('fs').rmSync('.tmp-path-tests',{recursive:true,force:true})\"",
    "postinstall": "node scripts/copy-monaco.cjs"
  },
  "devDependencies": {
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.3",
    "typescript": "~5.9.3",
    "vite": "^7.2.4"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@tauri-apps/api": "^2.9.1",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@xyflow/react": "^12.10.1",
    "monaco-editor": "^0.55.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^9.0.1",
    "react-window": "^2.2.6",
    "remark-gfm": "^4.0.0"
  }
}
